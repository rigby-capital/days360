{
  "name": "@rcsf/days360",
  "version": "3.0.0",
  "description": "Calculate the difference between two dates based on the 360-day financial year (30/360 day-count convention)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "days360",
    "360-day-year",
    "30/360",
    "30US/360",
    "30E/360",
    "day-count",
    "financial",
    "finance"
  ],
  "author": "Rigby Capital",
  "contributors": [
    "SpaceCraft <developers@gospacecraft.com>",
    "David Wood <david@gospacecraft.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rigby-capital/days360.git"
  },
  "bugs": "https://github.com/rigby-capital/days360/issues",
  "homepage": "https://github.com/rigby-capital/days360",
  "engines": {
    "node": ">= 20"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
